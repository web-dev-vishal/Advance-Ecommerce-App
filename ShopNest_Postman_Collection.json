              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Product Name", "type": "text" },
                { "key": "description", "value": "Product Description", "type": "text" },
                { "key": "price", "value": "99.99", "type": "text" },
                { "key": "category", "value": "Electronics", "type": "text" },
                { "key": "stock", "value": "50", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
