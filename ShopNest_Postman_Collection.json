        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"user@gmail.com\",\n  \"password\": \"pass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{endpoint}}/api/auth/register",
